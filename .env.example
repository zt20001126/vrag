# ============================================================
# Vision RAG Environment Configuration Example
# ============================================================
# Copy this file to .env and replace [REQUIRED] values.


# ============================================================
# 1. Application Basic Config [OPTIONAL]
# ============================================================
PROJECT_NAME=vision-rag
API_VERSION=0.1.0
API_PREFIX=/api/v1
DEBUG=true
LOG_LEVEL=info


# ============================================================
# 2. File Storage Config [OPTIONAL]
# ============================================================
UPLOAD_DIR=data/uploads
STORAGE_TYPE=local
MAX_UPLOAD_SIZE_MB=10


# ============================================================
# 3. Database Config: PostgreSQL + pgvector [OPTIONAL]
# ============================================================
DATABASE_URL=postgresql+psycopg://vision_rag:vision_rag_password@localhost:5432/vision_rag
VECTOR_DIM=512


# ============================================================
# 4. DeepSeek LLM Config [REQUIRED]
# ============================================================
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat


# ============================================================
# 5. Alibaba Cloud Bailian API Config [REQUIRED]
# ============================================================
ALIYUN_API_KEY=your_aliyun_api_key_here


# ============================================================
# 6. Alibaba Cloud Bailian Embedding Config [OPTIONAL]
# ============================================================
ALIYUN_EMBEDDING_API_URL=https://dashscope.aliyuncs.com/api/v1/services/embeddings/multimodal-embedding/multimodal-embedding
ALIYUN_EMBEDDING_MODEL=qwen3-vl-embedding
ALIYUN_EMBEDDING_DIMENSION=512


# ============================================================
# 7. Alibaba Cloud Bailian Image Generation Config [OPTIONAL]
# ============================================================
ALIYUN_IMAGE_GENERATION_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text2image/image-synthesis
ALIYUN_IMAGE_MODEL=wanx2.1-t2i-turbo


# ============================================================
# 8. Runtime Request Config [OPTIONAL]
# ============================================================
REQUEST_TIMEOUT_SECONDS=30


# ============================================================
# 9. RAG Retrieval Config [OPTIONAL]
# ============================================================
TOP_K=5
SIMILARITY_METRIC=cosine
DESIGNER_FILTER_ENABLED=true
